{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["paper_type", "research_area", "evidence", "confidence"],
  "properties": {
    "paper_type": {
      "$ref": "#/$defs/paper_type"
    },
    "research_area": {
      "$ref": "#/$defs/research_area"
    },
    "evidence": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "$ref": "#/$defs/confidence"
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "properties": {
        "notes": {
          "oneOf": [
            { "type": "string" }
          ]
        }
      }
    },
    {
      "required": ["confidence"]
    }
  ],
  "$defs": {
    "paper_type": {
      "type": "string",
      "enum": ["survey", "benchmark", "method", "evaluation", "dataset"]
    },
    "research_area": {
      "type": "string",
      "enum": [
        "retrieval_augmented_generation",
        "long_context_reasoning",
        "agent_tool_use",
        "model_evaluation",
        "data_curation",
        "other"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    }
  }
}
